mod <- lm(y ~ x + z)
summary(mod)
## Create variables:
set.seed(123)
nTrial <- 500
x <- 1 + rnorm(nTrial, 0, 1) # create x as random variable
z <- 1 + 0.95 * x + rnorm(nTrial, 0, 1) # create z based on x
y <- 1 + 0.05 * x + 0.05 * z + rnorm(nTrial, 0, 1)  # create y based on x and z
## Assess collinearity:
cor(x,z) # depending on regression coefficient and level of noise in z
plot(x,z)
abline(lm(z~x),col="red",lwd=5)
## Effect of IV:
cor(x,y)
plot(x,y)
abline(lm(y~x),col="red",lwd=5)
## Effect of covariate:
cor(z,y)
plot(z,y)
abline(lm(y~z),col="red",lwd=5)
# ------------------------------------------------ #
## Regression:
mod <- lm(y ~ x + z)
summary(mod)
# a) Z wrt x:
mod <- lm(z ~ x)
zhat <- residuals(mod)
cor(z,zhat) # --> still quite correlated
cor(x,z) # somewhat correlated
cor(x,zhat) # --> de-correlated
## New regression:
mod <- lm(y ~ x + z)
summary(mod)
mod <- lm(y ~ x + zhat)
summary(mod)
