## Identify trials where round increment, but patch ID doesn't:
tooFastIdx <- 1 + which(diff(eventData$roundID) != 0 & diff(eventData$patchID) == 0)
cat(paste0("Identified ", length(tooFastIdx), " trials where round index proceeded too fast (", paste0(tooFastIdx, collapse = ", "),"); correct\n"))
# eventData[sort(c(tooFastIdx, tooFastIdx - 1, tooFastIdx - 2)), c("roundID", "patchID", "trialID", "eventType", "forageBP")]
## Correct round index:
eventData[tooFastIdx, "roundID"] <- eventData[tooFastIdx - 1, "roundID"]
}
# ======================================================================== #
#### Define TT for entire round: ####
cat(paste0("Assign TT to all events in given round\n"))
roundVec <- sort(unique(eventData$roundID))
nRound <- length(roundVec)
for (iRound in 1:nRound){
roundIdx <- roundVec[iRound]
eventIdx <- which(eventData$roundID == roundIdx) # identify trials in round
roundTT <- max(eventData$TT[eventIdx], na.rm = T) # identify maximum TT
eventData$TT[eventIdx] <- roundTT # assign to all events in this round
}
stopifnot(sum(is.na(eventData$TT)) == 0)
# ======================================================================== #
# ======================================================================== #
# ======================================================================== #
# ======================================================================== #
# ======================================================================== #
#### Aggregate into trials/ dives: ####
cat(paste0("Aggregate events per trial\n"))
## Assign unique identifier to each trial (comprising multiple events):
eventData$round_patch_trial <- eventData$roundID * 10000 + eventData$patchID * 100 + eventData$trialID # unique ID for each trial # NA for travel events
# stopifnot(all(diff(eventData$round_patch_trial) >= 0, na.rm = T)) # check for monotonic increase
# plot(eventData$round_patch_trial)
# ------------------------------------------- #
# ## Identify violations of monotonic increase:
# outIdx <- which(diff(eventData$round_patch_trial) < 0)
# cat(paste0("Found ", length(outIdx), " trials that violate monotic increase: ", paste(outIdx, collapse = ", "), "\n"))
#
# ## Select trial:
# iSel <- 1 # select trial index
# nRange <- 2 # select range around trial:
# selIdx <- (outIdx[iSel] - nRange):(outIdx[iSel] + nRange)
# ## Print:
# cat(paste0("Print row ", outIdx[iSel], ":\n"))
# eventData[outIdx[iSel], c("roundID", "patchID", "trialID", "eventType", "forageBP", "travelBP", "round_patch_trial")]
# eventData[selIdx, c("roundID", "patchID", "trialID", "eventType", "forageBP", "travelBP", "round_patch_trial")]
# ------------------------------------------- #
## Loop over trials:
trialVec <- sort(unique(eventData$round_patch_trial)) # identify all trials
nTrial <- length(trialVec)
cat(paste0("Found ", nTrial, " trials\n"))
## Delete and initialize old output object:
if (exists("trialData")){rm(trialData)}
trialData <- data.frame()
# trialData <- data.frame(subjectID = rep(subjectID, nTrial))
for (iTrial in 1:nTrial){ # iTrial <- 1
# ---------------------------------------------------------------------- #
## Trial features that change on every trial:
trialIdx <- trialVec[iTrial]
rowIdx <- which(eventData$round_patch_trial == trialIdx)
stopifnot(all(diff(rowIdx) == 1)) # check that directly adjacent
selRoundID <- max(eventData$roundID[rowIdx])
selPatchID <- max(eventData$patchID[rowIdx])
startFRR <- max(eventData$instFRR[eventData$roundID == selRoundID & eventData$patchID == selPatchID], na.rm = T)
nRow <- length(rowIdx)
# ---------------------------------------------------------------------- #
## Identifiers:
trialData[iTrial, "subject_n"] <- subjectID
trialData[iTrial, "schedule_n"] <- scheduleID
trialData[iTrial, "round_n"] <- eventData[rowIdx[1], "roundID"]
trialData[iTrial, "patch_n"] <- eventData[rowIdx[1], "patchID"]
trialData[iTrial, "trial_n"] <- eventData[rowIdx[1], "trialID"]
# ---------------------------------------------------------------------- #
## Task variables:
trialData[iTrial, "FRR_n"] <- startFRR # max(eventData[rowIdx, "instFRR"], na.rm = T)
trialData[iTrial, "BRR_n"] <- eventData[rowIdx[1], "pRich"]
trialData[iTrial, "TT_n"] <- eventData[rowIdx[nRow], "TT"]
trialData[iTrial, "valence_n"] <- ifelse(eventData[rowIdx[nRow], "valence"] == "gain", 1, 0)
trialData[iTrial, "effort_n"] <- eventData[rowIdx[1], "effort"]
# ---------------------------------------------------------------------- #
## Choice:
if ("forage" %in% eventData[rowIdx, "eventType"]){
trialData[iTrial, "choice_n"] <- 0
trialData[iTrial, "outcome_n"] <- eventData[rowIdx[1], "outcome"]
} else {
trialData[iTrial, "choice_n"] <- 1
trialData[iTrial, "outcome_n"] <- NA
}
# ---------------------------------------------------------------------- #
## Button presses:
if ("forage" %in% eventData[rowIdx, "eventType"]){
trialData[iTrial, "forage_presses_n"] <- max(eventData[rowIdx, "forageBP"], na.rm = T)
trialData[iTrial, "travel_presses_n"] <- NA
} else {
trialData[iTrial, "forage_presses_n"] <- NA
trialData[iTrial, "travel_presses_n"] <- max(eventData[rowIdx, "travelBP"], na.rm = T) + 1 # first one not counted
}
# ---------------------------------------------------------------------- #
### RTs:
RTdevVec <- abs(eventData[, "forageTime"] - (eventData[, "absTime"] - eventData[, "tryStartTime"]))
if(any(RTdevVec > 5, na.rm = T)){
warning(paste0("Subject ", subjectID, ": forageTime off by up to ", max(RTdevVec, na.rm = T), " ms"))
}
if ("forage" %in% eventData[rowIdx, "eventType"]){
trialData[iTrial, "forage_RT_first_n"] <- eventData[rowIdx[1], "forageTime"] # RT of first button press
trialData[iTrial, "forage_RT_complete_n"] <- eventData[rowIdx[trialData[iTrial, "effort_n"]], "forageTime"] # RT of last required button press
trialData[iTrial, "forage_RT_last_n"] <- eventData[max(rowIdx, na.rm = T), "forageTime"] # RT of last button press
} else {
# Define RT for travel button presses? Harder; maybe first, but later ones often not align to start of button becoming available...
trialData[iTrial, "forage_RT_first_n"] <- NA
trialData[iTrial, "forage_RT_complete_n"] <- NA
trialData[iTrial, "forage_RT_last_n"] <- NA
}
# ---------------------------------------------------------------------- #
## Lives:
trialData[iTrial, "barScore_n"] <- round(max(eventData[rowIdx, "barScore"], na.rm = T))
trialData[iTrial, "nLives_n"] <- max(eventData[rowIdx, "nLives"], na.rm = T)
trialData[iTrial, "nTotalReward_n"] <- max(eventData[rowIdx, "nTotalReward"], na.rm = T)
# ---------------------------------------------------------------------- #
## Timing of first and last event in trial:
trialData[iTrial, "trialMinTime"] <- min(eventData[rowIdx, "absTime"], na.rm = T)
trialData[iTrial, "trialMaxTime"] <- max(eventData[rowIdx, "absTime"], na.rm = T)
} # end loop iTrial
# ------------------------------------------------------------------------ #
# ------------------------------------------------------------------------ #
# ------------------------------------------------------------------------ #
# ------------------------------------------------------------------------ #
# ------------------------------------------------------------------------ #
## Check for forage trials with undefined outcome:
cat(paste0("Found ", sum(is.na(trialData$outcome_n[trialData$choice_n == 0])), " trials where outcome is NA\n"))
stopifnot(sum(trialData$choice_n == 0 & is.na(trialData$outcome_n)) == 0)
## Check for finished travel trials:
# stopifnot(sum(trialData$choice_n == 1 & trialData$travel_presses_n < trialData$TT_n) == 0)
# ------------------------------------------------------------------------ #
### Remove trials with undefined FRR:
# forageIdx <- which(trialData$choice_n == 0)
# cat(paste0("Found ", sum(is.na(trialData$outcome_n[forageIdx])), " trials where FRR is NA\n"))
# cat(paste0("Found ", sum(is.infinite(trialData$outcome_n[forageIdx])), " trials where FRR is Inf\n"))
# ## Print trials around mismatch:
# naIdx <- which(trialData$choice_n == 0 & is.na(trialData$outcome_n))
# startIdx <- naIdx[1]
# nTrialRange <- 5
# selIdx <- c((startIdx - nTrialRange):(startIdx + nTrialRange)); # selIdx
# print(trialData[selIdx, ])
# ----------------------------------------------- #
### Could be recovered from schedule?
# ## Detect trial indices:
# print(trialData[startIdx, c("schedule_n", "round_n", "patch_n", "trial_n")])
# iRound <- trialData[startIdx, "round_n"]; iRound
# iPatch <- trialData[startIdx, "patch_n"]; iPatch
# iTrial <- trialData[startIdx, "trial_n"]; iTrial
# cat(paste0("Detected NA for outcome in round ", iRound, ", patch ", iPatch, ", trial ", iTrial, "\n"))
#
# trialIdx <- iRound * 10000 + iPatch * 100 + iTrial
#
# iPatch <- 5
#
# ## Print data for patch:
# patchIdx <- which(trialData$round_n == iRound & trialData$patch_n == iPatch)
# trialData[patchIdx, 1:12]
#
# ## Outcomes in schedule:
# jsonData$sched[[1]]$env[[iRound + 2]]$outc[[iPatch]][iTrial] # outcome for selected trial
# jsonData$sched[[1]]$env[[iRound + 2]]$outc[[iPatch]][1:(length(patchIdx) - 1)] # outcomes for entire patch (foraging dives)
# # sched$env[[1]]$outc
# ------------------------------------------------------------------------ #
#### Remove trials with undefined FRR: ####
cat(paste0("Found ", sum(is.na(trialData$FRR_n)), " trials where FRR is NA\n"))
cat(paste0("Found ", sum(is.infinite(trialData$FRR_n)), " trials where FRR is Inf\n"))
abortIdx <- is.infinite(trialData$FRR_n) # identify trials without identified outcome --> aborted
cat(paste0("Remove ", sum(abortIdx), " trials belonging to aborted dives\n"))
trialData <- trialData[!abortIdx, ]
nTrial <- nrow(trialData) # update trial number
# ------------------------------------------------------------------------ #
#### Add trial onset times: ####
## Include finished trials and unfinished travel trials:
# trlIdx <- which(jsonData$trials$finished == 1) # identify completed trials
trlIdx <- which((jsonData$trials$type == "travel") | (jsonData$trials$finished == 1)) # identify completed trials
nTrialTimings <- length(trlIdx)
if (nTrial == nTrialTimings){
## still includes aborted trials and travels...
## Check that trial types (forage/ travel) match:
stopifnot(all(as.numeric(jsonData$trials$type[trlIdx] == "travel") == trialData$choice_n))
# plot(trialData$choice_n, type = "l", lty = 2)
# lines(as.numeric(jsonData$trials$type[trlIdx] == "travel"), type = "l", lty = 2, col = "red")
cat("Number of trials and number of trial timings match; assign trial timings to trials")
trialData$trialOnset <- as.numeric(unlist(jsonData$trials$start_time[trlIdx]))
trialData$outcomeOnset <- as.numeric(unlist(jsonData$trials$stop_time[trlIdx]))
} else {
stop("Data has ", nTrial, " trials; trial timings has ", nTrialTimings, " valid trials; stop")
# --------------------------------------------- #
## Detect mismatch:
# plot(as.numeric(unlist(jsonData$trials$start_time[trlIdx])))
## Plot trial type from trial timings:
typeVec <- as.numeric(unlist(jsonData$trials$type[trlIdx] == "forage"))
plot(typeVec, type = "l", lty = 2)
nIdx <- min(nTrial, nTrialTimings)
## Plot trial type from behavioural data:
choiceVec <- 1 - trialData$choice_n
lines(choiceVec, type = "l", lty = 2, col = "red")
## Find first trial where both vectors mismatch:
startIdx <- min(which(typeVec[1:nIdx] - choiceVec[1:nIdx] != 0)); # startIdx
cat(paste0("First mismatch between vectors is on trial ", startIdx, "\n"))
nTrialRange <- 7
selIdx <- c((startIdx - nTrialRange):(startIdx + nTrialRange)); # selIdx
cat(paste0("Print and plot range of ", nTrialRange, " around trial ", startIdx, "\n"))
## Plot:
LWD <- 3
plot(selIdx, typeVec[selIdx], type = "l", ylim = c(0, 1.1),
lty = 5, lwd = LWD, main = "Choices given behaviour and trial timings")
lines(selIdx, choiceVec[selIdx], type = "l",
lty = 2, lwd = LWD, col = "red")
abline(v = startIdx, lwd = LWD)
legend("top", legend = c("TrialTimings", "Behav"),
col = c("black", "red"), border = 0, lwd = LWD, cex = 1, horiz = T, bty = "n") # double the LWD, half the CEX
## Print trials around mismatch:
print(trialData[startIdx, c("round_n", "patch_n", "trial_n", "choice_n", "outcome_n", "forage_presses_n", "travel_presses_n", "trialMinTime", "trialMaxTime")])
print(trialData[selIdx, c("round_n", "patch_n", "trial_n", "choice_n", "outcome_n", "forage_presses_n", "travel_presses_n", "trialMinTime", "trialMaxTime")])
eventData[eventData$roundID == trialData[startIdx, "round_n"]  & eventData$patchID == trialData[startIdx, "patch_n"],
c("roundID", "patchID", "trialID", "eventType", "outcome", "forageBP", "travelBP")]
trialData[trialData$round_n == trialData[startIdx, "round_n"] & trialData$patch_n == trialData[startIdx, "patch_n"],
c("round_n", "patch_n", "trial_n", "choice_n", "outcome_n", "forage_presses_n", "travel_presses_n", "trialMinTime", "trialMaxTime")]
cbind(jsonData$trials$type[(startIdx - 5):startIdx], jsonData$trials$finished[(startIdx - 5):startIdx])
}
# ------------------------------------------------------------------------ #
### Inspect briefly:
# head(trialData, n = 20)
## Check choices:
stopifnot(sum(is.na(trialData$choice_n)) == 0) # choices should always be defined
stopifnot(sum(is.na(trialData$outcome_n) & trialData$choice_n == 0) == 0) # outcomes for foraging choices should always be defined
## Check any remaining NAs:
# colSums(is.na(trialData)) # NAs per variable
# trialData[is.na(trialData$TT_n), ] # NA when finishing round foraging without final travel
# trialData[is.na(trialData$effort_n), ] # NA for leave trials, will be changed below
# trialData[is.na(trialData$outcome_n), ] # NA for leave trials
# trialData[is.na(trialData$forage_presses_n), ] # NA for leave trials
# head(trialData, n = 20)
# ======================================================================== #
#### Retrieve required effort for leave trials: ####
cat(paste0("Retrieve effort for leave trials\n"))
noEffortIdx <- which(is.na(trialData$effort_n)) # trials with effort info missing
# trialData[noEffortIdx, ]
stopifnot(all(trialData[noEffortIdx, "choice_n"] == 1)) # check that all NAs are leave trials
# trialData[is.na(trialData$effort_n) & trialData$choice_n == 0, ] # otherwise inspect which foraging trials affected
trialData[noEffortIdx, "effort_n"] <- trialData[noEffortIdx - 1, "effort_n"] # copy over from directly preceding foraging trial
# alternative: take mean per patch, assign to all
stopifnot(sum(is.na(trialData$effort_n)) == 0) # check that all NAs gone
# ======================================================================== #
#### Adjust round IDs: ####
roundVec <- sort(unique(trialData$round_n)) # all rounds identified
trialData$round_n <- trialData$round_n - min(trialData$round_n) + jsonData$info$startBlockID # reset so rounds from 1 to nRound --> can be used as indices
# trialData$round_n <- roundVec[trialData$round_n]
# table(trialData$round_n)
## Adjust patch IDs:
trialData$patch_n <- trialData$patch_n - min(trialData$patch_n) + 1 # reset so rounds from 1 to nRound --> can be used as indices
## Adjust trial IDs:
trialData$trial_n <- trialData$trial_n - min(trialData$trial_n) + 1 # reset so rounds from 1 to nRound --> can be used as indices
# trialData$round_patch_trial <- trialData$round_n * 10000 + trialData$patch_n * 100 + trialData$trial_n # add together as identifier?
# ======================================================================== #
#### Save behavioural data: ####
cat(paste0("Save subject ", subjectID, " as ", outFileName, "\n"))
write.csv(trialData, fullOutFileName, row.names = F)
cat(paste0("Finished subject ", subjectID, " :-)\n"))
# ======================================================================== #
#### Save trial timings: ####
cat(paste0("Save trial timings for subject ", subjectID, " ...\n"))
trialMat <- data.frame(trial_n = 1:jsonData$trials$count,
type_f = jsonData$trials$type,
finished_n = jsonData$trials$finished,
start_time = jsonData$trials$start_time,
stop_time = jsonData$trials$stop_time)
outFileName <- paste0("fishfmri_trials_sub_", str_pad(round(subjectID), nPad, side = "left", pad = "0"), ".csv")
fullOutFileName <- paste0(dirs$output, "trials/", outFileName)
write.csv(trialMat, fullOutFileName, row.names = F)
cat(paste0("Finished subject ", subjectID, " :-)\n"))
# ======================================================================== #
#### Save trigger timings: ####
cat(paste0("Save triggers for subject ", subjectID, " ...\n"))
triggerMat <- data.frame(trigger_n = 1:jsonData$triggers$count,
time_n = jsonData$triggers$timing)
outFileName <- paste0("fishfmri_triggers_sub_", str_pad(round(subjectID), nPad, side = "left", pad = "0"), ".csv")
fullOutFileName <- paste0(dirs$output, "triggers/", outFileName)
write.csv(triggerMat, fullOutFileName, row.names = F)
cat(paste0("Finished subject ", subjectID, " :-)\n"))
}
} # end for loop
end.time <- Sys.time(); beep()
dif <- difftime(end.time,start.time); dif
